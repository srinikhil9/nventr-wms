# =============================================================================
# WMS — copy to `.env.local` for local dev. On Vercel, set these in Project Settings → Environment Variables.
# =============================================================================

# MongoDB Atlas connection string (required for Prisma)
#
# Get yours from: MongoDB Atlas → Database → Connect → Drivers → Connection string
# Make sure to include the database name (e.g. /wms) in the path.
DATABASE_URL="mongodb+srv://user:password@cluster.mongodb.net/wms?retryWrites=true&w=majority"

# Supabase Auth (required for login — API URL + anon key)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Optional: Supabase service role — server-only; never expose to the client.
# SUPABASE_SERVICE_ROLE_KEY=""
